<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Medicinal Mushroom Guide</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F9F5EE;
    --dark: #1C1A14;
    --moss: #4A6741;
    --moss-light: #D4E6CE;
    --gold: #B8943F;
    --gold-light: #F5E9CC;
    --rust: #8B4A2B;
    --rust-light: #F2DDD4;
    --slate: #3A4A5C;
    --slate-light: #D5DDE8;
    --lavender: #6B5B8A;
    --lavender-light: #E5DFEF;
    --amber: #9C6B1A;
    --amber-light: #F7EDDA;
    --warn-red: #8B2020;
    --warn-bg: #F9E5E5;
    --border: rgba(28,26,20,0.12);
    --shadow: 0 2px 20px rgba(28,26,20,0.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--dark);
    line-height: 1.7;
    font-size: 15px;
  }

  /* HERO */
  .hero {
    background: var(--dark);
    color: var(--cream);
    padding: 80px 24px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(74,103,65,0.4) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(184,148,63,0.3) 0%, transparent 50%);
  }
  .hero-content { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; }
  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    font-weight: 500;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 6vw, 56px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .hero h1 em { font-style: italic; color: var(--gold); }
  .hero p {
    font-size: 16px;
    color: rgba(249,245,238,0.7);
    max-width: 480px;
    margin: 0 auto 32px;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .hero-stat { text-align: center; }
  .hero-stat .num { font-family: 'Playfair Display', serif; font-size: 32px; color: var(--gold); }
  .hero-stat .lbl { font-size: 11px; color: rgba(249,245,238,0.5); text-transform: uppercase; letter-spacing: 0.1em; }

  /* NAV */
  .nav {
    background: var(--dark);
    border-top: 1px solid rgba(255,255,255,0.08);
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .nav::-webkit-scrollbar { display: none; }
  .nav a {
    color: rgba(249,245,238,0.6);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 20px;
    white-space: nowrap;
    transition: color 0.2s;
    border-bottom: 2px solid transparent;
  }
  .nav a:hover { color: var(--cream); border-bottom-color: var(--gold); }

  /* LAYOUT */
  .container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  section { padding: 60px 0; border-bottom: 1px solid var(--border); }
  section:last-child { border-bottom: none; }

  .section-header { margin-bottom: 36px; }
  .section-eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--moss);
    margin-bottom: 8px;
  }
  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 700;
    color: var(--dark);
  }
  .section-header p { color: #666; margin-top: 8px; font-size: 14px; }

  /* MUSHROOM CARDS */
  .mush-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
  .mcard {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }
  .mcard:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
  .mcard-accent { height: 5px; }
  .mcard-body { padding: 20px; }
  .mcard-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 10px;
  }
  .mcard-name {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .mcard-sci { font-size: 12px; color: #888; font-style: italic; margin-bottom: 14px; }
  .mcard-benefits { list-style: none; padding: 0; }
  .mcard-benefits li {
    font-size: 13px;
    color: #555;
    padding: 5px 0;
    padding-left: 16px;
    position: relative;
    border-bottom: 1px solid rgba(28,26,20,0.05);
  }
  .mcard-benefits li:last-child { border-bottom: none; }
  .mcard-benefits li::before { content: "→"; position: absolute; left: 0; color: #aaa; font-size: 11px; top: 6px; }
  .mcard-note {
    margin-top: 12px;
    background: var(--warn-bg);
    border-left: 3px solid #c0392b;
    border-radius: 0 8px 8px 0;
    padding: 8px 12px;
    font-size: 12px;
    color: var(--warn-red);
    line-height: 1.5;
  }

  /* COLOR THEMES */
  .theme-moss .mcard-accent { background: var(--moss); }
  .theme-moss .mcard-tag { background: var(--moss-light); color: var(--moss); }
  .theme-moss .mcard-name { color: var(--moss); }

  .theme-gold .mcard-accent { background: var(--gold); }
  .theme-gold .mcard-tag { background: var(--gold-light); color: var(--amber); }
  .theme-gold .mcard-name { color: var(--amber); }

  .theme-rust .mcard-accent { background: var(--rust); }
  .theme-rust .mcard-tag { background: var(--rust-light); color: var(--rust); }
  .theme-rust .mcard-name { color: var(--rust); }

  .theme-slate .mcard-accent { background: var(--slate); }
  .theme-slate .mcard-tag { background: var(--slate-light); color: var(--slate); }
  .theme-slate .mcard-name { color: var(--slate); }

  .theme-lavender .mcard-accent { background: var(--lavender); }
  .theme-lavender .mcard-tag { background: var(--lavender-light); color: var(--lavender); }
  .theme-lavender .mcard-name { color: var(--lavender); }

  .theme-dark .mcard-accent { background: var(--dark); }
  .theme-dark .mcard-tag { background: #eee; color: #555; }
  .theme-dark .mcard-name { color: var(--dark); }

  /* SYNERGY TABLE */
  .synergy-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
  .syn-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 20px;
  }
  .syn-pair {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .syn-pill {
    font-size: 12px;
    font-weight: 500;
    background: var(--dark);
    color: var(--cream);
    padding: 4px 12px;
    border-radius: 20px;
  }
  .syn-plus { font-size: 14px; color: #aaa; }
  .syn-goal {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--moss);
    margin-bottom: 6px;
  }
  .syn-desc { font-size: 13px; color: #666; line-height: 1.5; }

  /* CAUTION CARDS */
  .caution-list { display: flex; flex-direction: column; gap: 12px; }
  .caution-card {
    background: var(--warn-bg);
    border: 1px solid rgba(139,32,32,0.2);
    border-radius: 12px;
    padding: 16px 20px;
  }
  .caution-title { font-size: 14px; font-weight: 500; color: var(--warn-red); margin-bottom: 6px; }
  .caution-desc { font-size: 13px; color: #6b3030; line-height: 1.55; }

  /* 14 BLEND SECTION */
  .blend-header {
    background: var(--dark);
    color: var(--cream);
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 28px;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    align-items: center;
  }
  .blend-header-text h3 {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    margin-bottom: 4px;
  }
  .blend-header-text p { font-size: 13px; color: rgba(249,245,238,0.6); }
  .blend-stats {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-left: auto;
  }
  .blend-stat { text-align: center; }
  .blend-stat .n { font-family: 'Playfair Display', serif; font-size: 26px; color: var(--gold); }
  .blend-stat .l { font-size: 11px; color: rgba(249,245,238,0.5); }

  /* FOOTER */
  footer {
    background: var(--dark);
    color: rgba(249,245,238,0.5);
    text-align: center;
    padding: 40px 24px;
    font-size: 12px;
    line-height: 1.7;
  }
  footer strong { color: var(--gold); }

  @media (max-width: 600px) {
    .mush-grid { grid-template-columns: 1fr; }
    .synergy-grid { grid-template-columns: 1fr; }
    .hero { padding: 60px 20px 40px; }
    .hero-stats { gap: 24px; }
  }
</style>
</head>
<body>

<div class="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">A Comprehensive Reference Guide</div>
    <h1>The <em>Medicinal</em><br>Mushroom Guide</h1>
    <p>A comprehensive breakdown of health benefits, synergies, and interactions for 9 functional mushrooms + the 14 Mushroom Blend.</p>
